{% set default_cors = 'http://localhost:*,http://127.0.0.1:*,http://*:5173,http://*:15173' %}
POSTGRES_DB={{ tp2_postgres_db | default('clickdb') }}
POSTGRES_USER={{ tp2_postgres_user | default('clickuser') }}
POSTGRES_PASSWORD={{ tp2_postgres_password | default('clickpass') }}
{% if tp2_load_balancer_enabled | default(false) %}
APP_CORS_ALLOWED_ORIGIN_PATTERNS={{ tp2_cors_allowed_origin_patterns | default(default_cors ~ ',' ~ tp2_load_balancer_urls.frontend) }}
VITE_API_BASE_URL={{ tp2_load_balancer_urls.backend }}
{% else %}
APP_CORS_ALLOWED_ORIGIN_PATTERNS={{ tp2_cors_allowed_origin_patterns | default(default_cors) }}
VITE_API_BASE_URL={{ tp2_backend_url }}
{% endif %}
GRAFANA_ADMIN_USER={{ tp2_grafana_admin_user | default('admin') }}
GRAFANA_ADMIN_PASSWORD={{ tp2_grafana_admin_password | default('admin') }}
