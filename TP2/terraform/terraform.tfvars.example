load_balancer = {
  enabled        = true
  host           = "runner.local"
  http_port      = 80
  dashboard_port = 8088
  hostnames = {
    frontend   = "app.runner.local"
    backend    = "api.runner.local"
    prometheus = "prometheus.runner.local"
    grafana    = "grafana.runner.local"
  }
}

targets = {
  linux1 = {
    enabled     = true
    os          = "linux"
    host        = "192.0.2.10"
    user        = "ubuntu"
    port        = 22
    auth_ref    = "linux1"
    deploy_path = "/opt/clicktracker/TP1"
  }

  windows1 = {
    enabled     = true
    os          = "windows"
    host        = "192.0.2.20"
    user        = "Administrator"
    port        = 5986
    auth_ref    = "windows1"
    deploy_path = "C:\\clicktracker\\TP1"
  }
}

cloud_ready_providers = ["aws", "gcp", "azure", "alibaba"]
