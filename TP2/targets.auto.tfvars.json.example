{
  "targets": {
    "linux1": {
      "enabled": true,
      "os": "linux",
      "host": "192.0.2.10",
      "user": "ubuntu",
      "port": 22,
      "auth_ref": "linux1",
      "deploy_path": "/opt/clicktracker/TP1",
      "ports": {
        "frontend": 5173,
        "backend": 8080,
        "prometheus": 9090,
        "grafana": 3000
      }
    },
    "windows1": {
      "enabled": true,
      "os": "windows",
      "host": "192.0.2.20",
      "user": "Administrator",
      "port": 5986,
      "auth_ref": "windows1",
      "deploy_path": "C:\\clicktracker\\TP1",
      "ports": {
        "frontend": 5173,
        "backend": 8080,
        "prometheus": 9090,
        "grafana": 3000
      }
    }
  },
  "cloud_ready_providers": ["aws", "gcp", "azure", "alibaba"]
}
